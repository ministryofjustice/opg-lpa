{
  "name": "service-admin",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:js && npm run build:css && npm run build:images && npm run build:fonts",
    "build:js": "node_modules/.bin/esbuild --bundle web/assets/main.js --minify --outdir=public/assets/javascript --sourcemap --resolve-extensions=.mjs,.js",
    "build:css": "node_modules/.bin/sass --load-path . --style compressed --no-source-map web/assets/main.scss public/assets/stylesheets/all.css",
    "build:images": "mkdir -p public/assets/images && cp node_modules/govuk-frontend/dist/govuk/assets/images/* public/assets/images",
    "build:fonts": "mkdir -p public/assets/fonts && cp node_modules/govuk-frontend/dist/govuk/assets/fonts/* public/assets/fonts"
  },
  "dependencies": {
    "esbuild": "^0.28.0",
    "govuk-frontend": "^6.1.0",
    "moment": "^2.30.1",
    "sass": "^1.97.2"
  }
}
