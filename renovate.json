{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "docker:pinDigests"
  ],
  "branchPrefix": "renovate-",
  "labels": [
    "Renovate"
  ],
  "ignoreDeps": [
    "github.com/ministryofjustice/opg-terraform-aws-moj-ip-allow-list"
  ],
  "commitMessageAction": "Renovate update",
  "forkProcessing": "enabled",
  "lockFileMaintenance": {
    "enabled": false
  },
  "minimumReleaseAge": "7 days",
  "vulnerabilityAlerts": {
    "groupName": "Security Alerts",
    "dependencyDashboardApproval": false,
    "minimumReleaseAge": null,
    "rangeStrategy": "update-lockfile",
    "commitMessagePrefix": "[SECURITY]",
    "branchTopic": "{{{datasource}}}-{{{depName}}}-vulnerability",
    "prCreation": "immediate"
  },
  "prConcurrentLimit": 3,
  "schedule": ["* 6 1,15 * *"],
  "packageRules": [
    {
      "description": [
        "Lock versions of managed services",
        "Our local images need to match the managed services that we have in AWS"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchDepNames": [
        "redis",
        "postgres"
      ],
      "enabled": false
    },
    {
      "description": [
        "laminas-servicemanager network blockages (major)",
        "None of these packages can be (major) upgraded until everything supports laminas-servicemanager v4",
        "Some of them do already support servicemanager v4, but Composer doesn't support multiple dependency versions",
        "symfony/console is blocked because robmorgan/phinx doesn't support symfony/console v7 until 0.15.5"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "matchDatasources": [
        "packagist"
      ],
      "matchDepNames": [
        "laminas/laminas-servicemanager",
        "laminas/laminas-cache",
        "laminas/laminas-cache-storage-adapter-memory",
        "laminas/laminas-filter",
        "laminas/laminas-paginator",
        "laminas/laminas-view",
        "symfony/console"
      ],
      "enabled": false
    },
    {
      "description": [
        "laminas-servicemanager network blockages (minor)",
        "robmorgan/phinx has a nested dependency on psr/simple-cache:^2.0, which in turn requires laminas-cache v4 so is blocked by the v4 servicemanager blockage above"
      ],
      "matchUpdateTypes": [
        "minor"
      ],
      "matchDatasources": [
        "packagist"
      ],
      "matchDepNames": [
        "robmorgan/phinx"
      ],
      "enabled": false
    },
    {
      "description": [
        "cypress: bundle updates to package.json and dockerfile",
        "allow major version updates"
      ],
      "groupName": "Cypress",
      "matchUpdateTypes": [
        "major"
      ],
      "matchManagers": [
        "dockerfile",
        "npm"
      ],
      "matchPackageNames": [
        "/cypress/",
        "/locust/"
      ]
    },
    {
      "description": [
        "dev tools: allow major updates only for dev tools and aws-sdk",
        "note: this may fail if other packages depend on existing versions"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "matchManagers": [
        "composer"
      ],
      "matchPackageNames": [
        "vimeo/psalm",
        "phpunit/phpunit",
        "aws/aws-sdk-php"
      ]
    },
    {
      "description": [
        "Github Actions: bundle all updates together"
      ],
      "groupName": "Github Actions",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "matchManagers": [
        "github-actions"
      ]
    },
    {
      "description": [
        "Terraform: bundle all updates together"
      ],
      "groupName": "Terraform",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchManagers": [
        "terraform"
      ]
    },
    {
      "description": [
        "No updates to postgres, redis, php or python docker images",
        "postgres: keep in sync with live",
        "redis: keep in sync with live",
        "php: upgrade needs to be managed manually"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "matchManagers": [
        "dockerfile",
        "docker-compose",
        "composer"
      ],
      "matchPackageNames": [
        "postgres",
        "redis",
        "php",
        "python"
      ],
      "enabled": false
    },
    {
      "description": [
        "No updates to PHP PDF libraries (too sensitive and risky)"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch"
      ],
      "matchManagers": [
        "composer"
      ],
      "matchPackageNames": [
        "tecnickcom/tcpdf",
        "mikehaertl/php-pdftk"
      ],
      "enabled": false
    },
    {
      "groupName": "admin minor and patch updates (PHP)",
      "groupSlug": "admin-minor-patch-updates-php",
      "matchManagers": [
        "composer"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchFileNames": [
        "service-admin/composer.json"
      ],
      "prPriority": 4
    },
    {
      "groupName": "front minor and patch updates (PHP)",
      "groupSlug": "front-minor-patch-updates-php",
      "matchManagers": [
        "composer"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchFileNames": [
        "service-front/composer.json"
      ],
      "prPriority": 4
    },
    {
      "groupName": "front mezzio minor and patch updates (PHP)",
      "groupSlug": "front-mezzio-minor-patch-updates-php",
      "matchManagers": [
        "composer"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchFileNames": [
        "service-front/mezzio/composer.json"
      ],
      "prPriority": 4
    },
    {
      "groupName": "api minor and patch updates (PHP)",
      "groupSlug": "api-minor-patch-updates-php",
      "matchManagers": [
        "composer"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchFileNames": [
        "service-api/composer.json"
      ],
      "prPriority": 4
    },
    {
      "groupName": "pdf minor and patch updates (PHP)",
      "groupSlug": "pdf-minor-patch-updates-php",
      "matchManagers": [
        "composer"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchFileNames": [
        "service-pdf/composer.json"
      ],
      "prPriority": 4
    },
    {
      "groupName": "shared minor and patch updates (PHP)",
      "groupSlug": "shared-minor-patch-updates-php",
      "matchManagers": [
        "composer"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchFileNames": [
        "shared/composer.json"
      ],
      "prPriority": 4
    },
    {
      "groupName": "minor and patch updates (npm)",
      "groupSlug": "all-minor-patch-updates-npm",
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchFileNames": [
        "package.json",
        "service-front/package.json"
      ],
      "prPriority": 4
    },
    {
      "groupName": "minor and patch updates (Python)",
      "groupSlug": "all-minor-patch-updates-python",
      "matchManagers": [
        "pep621",
        "pip_requirements",
        "pip-compile",
        "pipenv",
        "pyenv",
        "setup-cfg",
        "pip_setup"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "prPriority": 4
    },
    {
      "groupName": "Docker images",
      "groupSlug": "docker-images",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "matchDatasources": [
        "docker"
      ],
      "prPriority": 4
    },
    {
      "groupName": "PHP major/minor upgrade",
      "matchUpdateTypes": [
        "major",
        "minor"
      ],
      "matchManagers": [
        "dockerfile"
      ],
      "matchPackageNames": [
        "php"
      ]
    }
  ]
}
