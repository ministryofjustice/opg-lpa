{% extends 'layout/layout.twig' %}

{%- set pageTitle = 'Service status' -%}

{% block content %}

<div class="service-status">
	<div>
		{% if status.status == 'pass' %}
			<h2 class="govuk-heading-m"><i class="icon icon-tick"></i> Service is up and running</h2>
		{% elseif status.status == 'warn' %}
			<h2 class="govuk-heading-m"><strong class="icon">⚠</strong> Service is running in a degraded state</h2>
		{% else %}
			<h2 class="govuk-heading-m"><i class="icon icon-cross"></i> Service is down</h2>
		{% endif %}

		<ul class="service-list">
			{% if status.dynamo.ok == true %}
				<li>
					<i class="icon icon-tick"></i>
					<p class="govuk-body govuk-!-margin-bottom-0">Database is up and running</p>
				</li>
			{% else %}
				<li>
					<i class="icon icon-cross"></i>
					<p class="govuk-body govuk-!-margin-bottom-0">Database is down</p>
				</li>
			{% endif %}
			{% if status.api.ok == true %}
				<li>
					{% if status.api.status == 'warn' %}
						<strong class="icon">⚠</strong>
					{% else %}
						<i class="icon icon-tick"></i>
					{% endif %}
					<p class="govuk-body govuk-!-margin-bottom-0">API service is up and running</p>
				</li>
				{% if status.api.status == 'warn' %}
	                <li>
	                    <p class="govuk-body-xs govuk-!-font-weight-bold govuk-!-margin-bottom-0" style="margin-left: 32px">(...but is in a degraded state)</p>
	                </li>
            	{% endif %}
			{% else %}
				<li>
					<i class="icon icon-cross"></i>
					<p class="govuk-body govuk-!-margin-bottom-0">API service is down</p>
				</li>
			{% endif %}
			{% if status.sessionSaveHandler.ok == true %}
				<li>
					<i class="icon icon-tick"></i>
					<p class="govuk-body govuk-!-margin-bottom-0">Session storage is up and running</p>
				</li>
			{% else %}
				<li>
					<i class="icon icon-cross"></i>
					<p class="govuk-body govuk-!-margin-bottom-0">Session storage is down</p>
				</li>
			{% endif %}
			{% if status.mail.ok == true %}
				<li>
					<i class="icon icon-tick"></i>
					<p class="govuk-body govuk-!-margin-bottom-0">Mail transport is up and running</p>
				</li>
			{% else %}
				<li>
					<i class="icon icon-cross"></i>
					<p class="govuk-body govuk-!-margin-bottom-0">Mail transport is down</p>
				</li>
			{% endif %}
            {% if status.ordnanceSurvey.ok == true %}
                <li>
                    <i class="icon icon-tick"></i>
                    <p class="govuk-body govuk-!-margin-bottom-0">Ordnance Survey postcode lookup is up and running</p>
                </li>
            {% else %}
                <li>
                    <i class="icon icon-cross"></i>
                    <p class="govuk-body govuk-!-margin-bottom-0">Ordnance Survey postcode lookup is down</p>
                </li>
            {% endif %}
            {% if status.ordnanceSurvey.cached == true %}
                <li>
                    <p class="govuk-body-xs govuk-!-font-weight-bold govuk-!-margin-bottom-0" style="margin-left: 32px">(The Ordnance Survey status is a cached response due to rate limiting)</p>
                </li>
            {% endif %}
		</ul>
	</div>
</div>


{% endblock content %}
