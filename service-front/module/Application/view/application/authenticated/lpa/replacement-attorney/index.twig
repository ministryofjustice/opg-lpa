{% extends 'layout/accordion-layout.twig' %}

{%- set pageTitle = 'Does the donor want any replacement attorneys?' -%}

{% block content %}

{% set form = formErrorTextExchange(form, {}) %}

<li id="replacement-attorney-section" class="section current" data-cy="section-current">

    <h1 class="govuk-heading-m accordion-header">{{ pageTitle }}</h1>

    <div class="accordion-info">
        <div class="govuk-grid-row"><div class="govuk-grid-column-two-thirds">
            <p class="govuk-body">Replacement attorneys step in if an original attorney can no longer act.</p>
            <p class="govuk-body">A replacement attorney must meet the same requirements as an original attorney. This includes being 18 or over.</p>

            {% if (lpa.document.primaryAttorneyDecisions) %}
                {% if (lpa.document.primaryAttorneyDecisions.how == 'jointly') %}
                <div class="govuk-inset-text">
                    <h2 class="govuk-heading-s govuk-!-margin-top-0">Replacement attorneys are an important backup when attorneys are appointed to act jointly.</h2>
                    <p class="govuk-body">If the donor does not appoint any replacement attorneys and one of the original attorneys dies or can no longer act, the LPA will stop working.</p>
                    <p class="govuk-body">If the donor does appoint replacement attorneys and one of the original attorneys dies or can no longer act:</p>
                    <ul class="list list-bullet">
                        <li>
                            <p class="govuk-body"><strong class="govuk-!-font-weight-bold">ALL the original attorneys will be replaced by the replacement attorneys, unless the donor states otherwise in their instructions</strong></p>
                        </li>
                        <li>
                            <p class="govuk-body"><strong class="govuk-!-font-weight-bold">the original attorneys will not be able to make any decisions on the donor's behalf anymore</strong></p>
                        </li>
                    </ul>
                    <p class="govuk-body">If the donor wants to change how their replacement attorneys step in, they can explain their wishes in the instructions section.</p>
                </div>
                {% elseif (lpa.document.primaryAttorneyDecisions.how == 'depends') %}
                <div class="govuk-inset-text">
                    <h2 class="govuk-heading-s govuk-!-margin-top-0">The donor appointed their attorneys to act jointly for some decisions, and jointly and severally for others.</h2>
                    <p class="govuk-body">This means that if an original attorney dies or can no longer act:</p>
                    <ul class="list list-bullet">
                        <li>
                            <p class="govuk-body"><strong class="govuk-!-font-weight-bold">all the replacement attorneys step in and take over making the joint decisions</strong></p>
                        </li>
                        <li>
                            <p class="govuk-body"><strong class="govuk-!-font-weight-bold">the remaining original attorneys will not be able to make the joint decisions anymore, unless the donor states otherwise in their instructions</strong></p>
                        </li>
                        <li>
                            <p class="govuk-body"><strong class="govuk-!-font-weight-bold">the replacement and remaining original attorneys can make all other decisions together or individually</strong></p>
                        </li>
                    </ul>
                </div>
                {% endif %}
            {% endif %}

            <p class="govuk-body"><a class="govuk-link js-guidance" href="/guide#topic-replacement-attorneys" data-analytics-click="page:link:help: Find out more about replacement attorneys">Find out more about replacement attorneys</a></p>
        </div></div>
    </div>

    {% if (attorneys) %}
        <h2 class="govuk-heading-m flush--top">
            The replacement attorney{% if attorneys|length > 1 %}s{% endif %}
        </h2>
        <ul>
            {% for attorney in attorneys %}
                {% include 'application/authenticated/lpa/replacement-attorney/partials/attorney.twig' with attorney %}
            {% endfor %}
        </ul>
    {% endif %}

    <div class="{% if (attorneys) %}action-item{% endif %} govuk-!-margin-bottom-3">
        <a href="{{ addRoute }}" {% if not (attorneys)  %}role="button"{% endif %} data-cy="add-replacement-attorney" class="{% if not (attorneys) %}govuk-button{% else %}govuk-link{% endif %} js-form-popup">
            {% if (attorneys) %}
                Add another replacement attorney?
            {% else %}
                Add replacement attorney
            {% endif %}
        </a>
    </div>

    {# begin form #}
    {{ form.prepare() ? '' }}
    {{ form().openTag( form )|raw }}
        {{ formElement(form.getCsrf) }}
        {% if (attorneys) %}
            <div class="govuk-!-margin-bottom-3">
                {{ formElement(form.get('save')) }}
            </div>
        {% else %}
            {{ formElement(form.get('save')) }}
        {% endif %}
    {{ form().closeTag|raw }}

</li>

{% endblock %}
