{% extends isPopup ? 'layout/popup.twig' : 'layout/layout.twig' %}


{% block content %}

<header class="popup-header">
    <i class="icon icon-bin"></i>
    <h2 class="heading-small popup-header-title" id="dialog-title">
        Are you sure you want to delete this {% if isTrust %}trust corporation{% else %}person{% endif %}?
    </h2>
</header>

<div class="form">
    <h2 class="heading-medium">{{ attorneyName }}</h2>
    <p>{{ attorneyAddress }}</p>
    <div class="govuk-button-group">
        <a href="{{ deleteRoute }}" data-cy="delete" class="govuk-button govuk-button--warning">Delete</a>
        <a href="{{ cancelUrl }}" data-cy="cancel" class="govuk-button govuk-button--secondary js-cancel">Cancel</a>
    </div>
</div>


{% endblock %}
