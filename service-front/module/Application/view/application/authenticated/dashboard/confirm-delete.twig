{% extends isPopup ? 'layout/popup.twig' : 'layout/layout.twig' %}

{%- set pageTitle = 'Delete an LPA' -%}

{% block content %}

<header class="popup-header">
    <i class="icon icon-bin"></i>
    <h2 class="govuk-heading-s popup-header-title" id="dialog-title">Are you sure you want to delete this?</h2>
</header>

<div class="form">
    <h2 class="govuk-heading-m">
        {% if lpa.document.donor.name is defined %}
            {{ lpa.document.donor.name }}
        {% else %}
            No donor added
        {% endif %}
    </h2>
    <p class="govuk-body">{{ lpa.id | format_lpa_id }}</p>
    <p class="govuk-body">This will only delete the information on this website. It will not delete any LPA application you've sent to OPG already, or any registered LPA.</p>
    <div class="govuk-button-group">
        <a class="govuk-link" href="/user/dashboard/delete-lpa/{{ lpa.id }}{% if page > 1 %}?page={{ page }}{% endif %}" data-cy="delete" class="govuk-button govuk-button--warning js-single-use">Delete</a>
        <a href="/user/dashboard" data-cy="cancel" class="govuk-button govuk-button--secondary js-cancel">Cancel</a>
    </div>
</div>

{% endblock %}
