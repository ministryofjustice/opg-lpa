/* progress bar changes */
/* creates the triangle appended to the rectangles in the progress bar*/
.progress-bar {
  list-style: none;
  font: 19px Helvetica;
  font-weight: 600;
  counter-reset: li; /* necessary to insert numbers before text */
  width: 100%;
}
@media screen and (min-width: 768px) {
  .progress-bar {
    height: 50px;
    overflow: hidden; /* necessary to cut off top and bottom parts of triangles */
    display: flex;
  }
}
.progress-bar .progress-bar__steps {
  background: #dadada;
  color: #555555;
  position: relative;
  cursor: default;
  /* remove default ordered list number styles */
  list-style-image: none;
  list-style-type: none;
  padding: 8px 20px;
  text-align: left;
  margin-bottom: 7px;
}
.progress-bar .progress-bar__steps.current-waiting {
  background: #1d70b8;
  color: #ffffff;
}
.progress-bar .progress-bar__steps.current-waiting ::before {
  border: 2px solid #ffffff !important;
}
.progress-bar .progress-bar__steps.current-waiting::after {
  border-left: 30px solid #1d70b8;
}
.progress-bar .progress-bar__steps.current-received {
  background: #4c2c92;
  color: #ffffff;
}
.progress-bar .progress-bar__steps.current-received ::before {
  border: 2px solid #ffffff !important;
}
.progress-bar .progress-bar__steps.current-received::after {
  border-left: 30px solid #4c2c92;
}
.progress-bar .progress-bar__steps.current-checking {
  background: #912b88;
  color: #ffffff;
}
.progress-bar .progress-bar__steps.current-checking ::before {
  border: 2px solid #ffffff !important;
}
.progress-bar .progress-bar__steps.current-checking::after {
  border-left: 30px solid #912b88;
}
.progress-bar .progress-bar__steps.current-processed {
  background: #00703c;
  color: #ffffff;
}
.progress-bar .progress-bar__steps.current-processed ::before {
  border: 2px solid #ffffff !important;
}
.progress-bar .progress-bar__steps.current-processed::after {
  border-left: 30px solid #00703c;
}
.progress-bar .progress-bar__steps .progress-bar__steps--numbers:before {
  /* add ticks to the list items */
  content: counter(li) " ";
  counter-increment: li;
  /* separate the numbers from the text */
  margin-right: 5px;
  /* add background circles */
  background: transparent;
  border: 2px solid #555555;
  border-radius: 50%;
  display: inline-block;
  height: 30px;
  line-height: 30px; /* make the line-height the same as the height so that number aligns vertically */
  text-align: center;
  width: 30px;
}
.progress-bar .progress-bar__steps .progress-bar__steps--completed:before {
  /* add ticks to the list items */
  content: "✔";
  counter-increment: li;
  /* separate the numbers from the text */
  margin-right: 5px;
  /* add background circles */
  background: transparent;
  border: 2px solid #555555;
  border-radius: 50%;
  display: inline-block;
  height: 30px;
  line-height: 30px; /* make the line-height the same as the height so that number aligns vertically */
  text-align: center;
  width: 30px;
}
@media screen and (min-width: 768px) {
  .progress-bar .progress-bar__steps {
    width: calc(25% - 7.5px);
    padding: 8px 0 8px 45px;
    text-align: center;
    margin-bottom: 0;
  }
  .progress-bar .progress-bar__steps:first-child {
    padding-left: 10px;
  }
  .progress-bar .progress-bar__steps {
    /*prepend triangle cutout to create separation border */
  }
  .progress-bar .progress-bar__steps:before {
    border-left: 30px solid #ffffff;
    z-index: 1;
    margin-left: 8px;
    border-bottom: 50px solid transparent;
    border-top: 50px solid transparent;
    content: " ";
    display: block;
    height: 0;
    left: 100%;
    margin-top: -50px;
    position: absolute;
    top: 50%;
    width: 0;
  }
  .progress-bar .progress-bar__steps {
    /* appended triangle */
  }
  .progress-bar .progress-bar__steps:after {
    border-left: 30px solid #dadada;
    z-index: 2;
    margin-left: 0px;
    border-bottom: 50px solid transparent;
    border-top: 50px solid transparent;
    content: " ";
    display: block;
    height: 0;
    left: 100%;
    margin-top: -50px;
    position: absolute;
    top: 50%;
    width: 0;
  }
  .progress-bar .progress-bar__steps:last-child {
    padding-right: 10px;
  }
}

