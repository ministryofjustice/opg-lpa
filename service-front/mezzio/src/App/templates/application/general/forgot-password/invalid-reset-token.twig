{% extends 'layout/layout.twig' %}

{%- set pageTitle = 'That password link does not work' -%}

{% block content %}

<div class="govuk-body">
    <p class="govuk-body-l">You cannot reset your password with the link you've used.</p>
    <p>This might be because you've:</p>
    <ul class="govuk-list govuk-list--bullet">
        <li>already used this link</li>
        <li>tried to change your password again since</li>
        <li>changed the link</li>
    </ul>
    <p><a href="{{ url('forgot-password') }}">Get a new link</a> to reset your password.</p>
</div>

{% endblock content %}
