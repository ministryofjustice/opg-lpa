{% extends 'layout/layout.twig' %}

{%- if (error is empty) %}{% set pageTitle = 'Account activated' %}{% else %}{% set pageTitle = 'Account activation problem' %}{% endif -%}

{% block content %}

{% if (error is empty) %}

    <div class="govuk-body">
        <p class="govuk-body-l">Thank you. We've now activated your account.</p>
        <p class="govuk-body">Please <a class="govuk-link" href="{{ url('login') }}">sign in</a></p>
    </div>

{% else %}

    <div class="govuk-body">
        <p class="govuk-body-l">Sorry, we had a problem activating your account. This could be because:</p>

        <ul class="govuk-list govuk-list--bullet">
            <li>
                <p class="govuk-body govuk-!-font-weight-bold">You already have an active account</p>
                <p class="govuk-body">If so, you can sign in to the <a class="govuk-link" href="{{ url('login') }}">LPA online service</a> to create or complete an LPA.</p>
            </li>
            <li>
                <p class="govuk-body govuk-!-font-weight-bold">You created the account more than 24 hours ago</p>
                <p class="govuk-body">You need to activate your account within 24 hours of creating it. If you do not activate it within that time, we'll automatically delete it.</p>
                <p class="govuk-body">You should return to <a class="govuk-link" href="{{ url('register') }}">create an account</a> and complete again.</p>
            </li>
        </ul>

        <p class="govuk-body">If you need more help activating your account, email <a class="govuk-link" href="mailto:customerservices@publicguardian.gov.uk ">customerservices@publicguardian.gov.uk</a> or call 0300 456 0300.</p>

    </div>

{% endif %}

{% endblock content %}
