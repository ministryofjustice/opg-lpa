{% extends 'layout/layout.twig' %}

{%- set pageTitle = 'Final check: LPA details' -%}

{% set exemption = false %}
{% set remission = false %}
{% set notify = false %}

{% if lpa.payment.reducedFeeReceivesBenefits or lpa.payment.reducedFeeUniversalCredit %}
    {% set exemption = true %}
{% endif %}

{% if lpa.payment.reducedFeeLowIncome %}
    {% set remission = true %}
{% endif %}

{% if lpa.document.peopleToNotify is defined and lpa.document.peopleToNotify|length > 0 %}
    {% set notify = true %}
{% endif %}

{% block content %}

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <p class="govuk-body">Check all the details on this page are correct and everyone has agreed to be part of this lasting power of attorney before continuing.</p>
        </div>
    </div>

    {# Don't show 'Next steps' if CP has been skipped #}
    {% if (lpa.document.certificateProvider) %}
        <details role="group">
            <summary role="button" data-analytics-click="page:link.reveal:help: What do I need to do next?">
                <span class="summary">What do I need to do next?</span>
            </summary>
            <div class="govuk-inset-text">
                <ul class="list list-number">
                    <li>Click to confirm all the details on this page are correct</li>

                    {% if not exemption %}
                        <li>Next, pay the application fee online by card (you can also choose to pay by cheque)</li>
                    {% endif %}

                    <li>{% if exemption %}Next,{% else %}Then{% endif %} download and print the LPA, and get it signed and dated in the right order</li>

                    {% if exemption %}
                        <li>Then download, print, sign and date the fee remission and exemption form</li>
                    {% endif %}

                    {% if remission %}
                        <li>Download, print, sign and date the fee remissions form</li>
                    {% endif %}

                    {% if notify %}
                        <li>Download and print the people to notify form - give one to each person to notify</li>
                    {% endif %}

                    {% if exemption %}
                        <li>Finally, post the LPA to OPG, along with the fee remission and exemption form and proof of the donor’s benefits</li>
                    {% elseif remission %}
                        <li>Finally, post the LPA to OPG, along with the fee remissions form and proof of the donor’s income</li>
                    {% else %}
                        <li>Finally, post the LPA to OPG</li>
                    {% endif %}
                </ul>

                <p class="govuk-body">If there are no problems with the LPA, we'll register it and send it to the correspondent. If we cannot register the LPA, we'll write to the correspondent to let them know.</p>
            </div>
        </details>
    {% endif %}

    {% if (lpaIsCompleted) %}

        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds">
                <div class="govuk-warning-text govuk-!-margin-top-4">
                    <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                    <strong class="govuk-warning-text__text">
                        <span class="govuk-visually-hidden">Warning</span>
                        <p class="govuk-body govuk-!-font-weight-bold">At the next stage your forms will be ready to download and sign with the information shown below.</p>
                        <p class="govuk-body govuk-!-font-weight-bold">You will not be able to change anything in the LPA once you have clicked confirm.</p>
                    </strong>
                </div>
            </div>
        </div>

        <p class="govuk-body govuk-!-text-align-right">
            <a href="#" class="govuk-link js-print hide-if-no-js" data-analytics-click="page:link:Print this summary">
                <i class="icon icon-print" aria-hidden="true"></i>
                Print this summary
            </a>
        </p>

    {% endif %}

    {% import "application/macros.twig" as macros %}

    {% include 'application/authenticated/lpa/summary/partials/summary-table.twig' %}

    {% if (lpaIsCompleted) %}

        <div class="appstatus" role="alert">
            <h2 class="govuk-heading-xl">Confirm and
                {% if lpa.payment.amount == 0 %}finish{% else %}pay{% endif %}
            </h2>
            {% if lpa.payment.amount is null %}
                <h3 class="govuk-heading-m">We'll contact you about the fee</h3>
            {% else %}
                <h3 class="govuk-heading-m">Application fee: £{{ lpa.payment.amount | money_format }}</h3>
            {% endif %}
        </div>

        {% if lpa.payment.amount == 0 %}

            {# -- Nothing to pay -- #}
            <p class="govuk-body divorced"><a href="{{ url('lpa/checkout/confirm', {'lpa-id': lpa.id}) }}" role="button" class="govuk-button" data-cy="confirm-and-finish">Confirm and finish</a></p>

        {% else %}

            <details class="no-print-for-summary">
                <summary data-analytics-click="page:link.reveal:help: Why are you asking me to pay now?">
                    <span class="summary">Why are you asking me to pay now?</span>
                </summary>
                <div class="govuk-inset-text">
                    <p class="govuk-body">The fee covers the cost of processing your application, not just registering the LPA.</p>

                    <p class="govuk-body">If you pay by card but do not send it to OPG for registration within 42 days, we will automatically give you a refund.</p>

                    <p class="govuk-body">You can still post the LPA to us after you’ve been refunded - we’ll contact you and ask you to pay the fee again or you can send a cheque with the LPA.</p>

                    <p class="govuk-body">If you do not want to pay by card, you can choose to post a cheque with the LPA application. The instructions you'll download with the LPA explain how to pay by cheque.</p>
                </div>
            </details>

            <div class="govuk-warning-text govuk-!-margin-top-4">
                <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                <strong class="govuk-warning-text__text">
                    <span class="govuk-visually-hidden">Warning</span>
                    <p class="govuk-body">You will not be able to change anything in the LPA once you have clicked confirm.</p>
                </strong>
            </div>

            {# -- GDS Pay -- #}
            <p class="govuk-body divorced">
                {# begin form #}
                {{ form.prepare() ? '' }}
                {{ form().openTag( form )|raw }}
                <input type="hidden" name="__csrf" value="{{ csrfToken }}">

            <div class="govuk-form-group">
                {{ formElement(form.get('submit')) }}
                <a href="{{ url('lpa/checkout/cheque', {'lpa-id': lpa.id}) }}" class="govuk-link" data-cy="confirm-and-pay-by-cheque">Confirm and pay by cheque</a>
            </div>

            {{ form().closeTag|raw }}
            </p>

        {% endif %}

        <p class="govuk-body divorced">
            <a class="govuk-link" href="/user/dashboard" data-analytics-click="page:link:save: Save for later">Save for later</a>
        </p>

    {% else %}

        <div class="govuk-warning-text govuk-!-margin-top-4">
            <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
            <strong class="govuk-warning-text__text">
                <span class="govuk-visually-hidden">Warning</span>
                <p class="govuk-body">When you have chosen a certificate provider, you'll be able to continue.</p>
            </strong>
        </div>

        <a class="govuk-button" disabled="disabled">Confirm</a>
        <a href="/user/dashboard" class="govuk-link" data-analytics-click="page:link:save: Save for later">Save for later</a>

    {% endif %}

{% endblock %}
