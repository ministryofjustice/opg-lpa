{
  "name": "opg-lpa-3",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "npm run build:scsslint && npm run build:jshint",
    "build": "npm run build:js && npm run build:css && npm run build:fonts",
    "build:js": "npm run build:copy:jsenv && npm run build:handlebars && npm run build:concat && npm run build:uglify && npm run build:copy:jsdevgovuk && npm run build:copy:jsdevgovukinit",
    "build_js_dev": "copy:jsenv && handlebars && concat && copy:jsdev && copy:jsdevdashboardstatuses && copy:jsdevsessiontimeout && copy:jsdevinitpolyfill",
    "build:esbuild_of_js": "node_modules/.bin/esbuild --bundle web/assets/main.js --minify --outdir=public/assets/javascript --sourcemap --resolve-extensions=.mjs,.js",
    "build:css": "npm run build:sass && npm run build:replace && npm run build:copy:css && npm run build:copy:cssdevfonts && npm run build:cssmin",
    "build:cssmin": "echo 'TODO - no exact equivalent can test without'",
    "build:handlebars": "echo 'TODO - no exact equivalent can test without for now' && cat assets/js/lpa/templates/*.html > assets/js/lpa/lpa.templates.js",
    "build:concat": "./node-build-scripts/concat",
    "build:uglify": "./node_modules/.bin/uglifyjs public/assets/v2/js/application.js --output public/assets/v2/js/application.min.js && /node_modules/.bin/uglifyjs assets/js/opg/session-timeout-init.js --output public/assets/v2/js/opg/session-timeout-init.min.js && /node_modules/.bin/uglifyjs assets/js/opg/dashboard-statuses.js --output public/assets/v2/js/opg/dashboard-statuses.min.js && /node_modules/.bin/uglifyjs assets/js/opg/init-polyfill.js --output public/assets/v2/js/opg/init-polyfill.min.js",
    "build:fonts": "mkdir -p public/assets/v2/fonts && cp node_modules/govuk-frontend/dist/govuk/assets/fonts/* public/assets/v2/fonts",
    "build:copy:jsenv": "cp assets/js/opg/env-vars.template.js assets/js/opg/env-vars.js",
    "build:copy:jsdev": "cp public/assets/v2/js/application.js public/assets/v2/js/application.min.js",
    "build:copy:jsdevgovuk": "cp node_modules/govuk-frontend/dist/govuk/govuk-frontend.min.js public/assets/v2/js/govuk-frontend.min.js",
    "build:copy:jsdevgovukinit": "cp assets/js/opg/govuk-init.js public/assets/v2/js/govuk-init.js",
    "build:copy:jsdevsessiontimeout": "cp assets/js/opg/session-timeout-init.js public/assets/v2/js/opg/session-timeout-init.min.js",
  },
  "description": "Lasting Power of Attorney",
  "repository": "https://github.com/ministryofjustice/opg-lpa-front",
  "license": "MIT",
  "dependencies": {
    "esbuild": "^0.27.3",
    "govuk_template_mustache": "^0.26.0",
    "govuk-elements-sass": "^3.1.3",
    "govuk-frontend": "^5.11.1",
    "govuk_frontend_toolkit": "^9.0.1",
    "grunt": "^1.5.3",
    "grunt-cli": "^1.3.2",
    "grunt-contrib-concat": "^1.0.1",
    "grunt-contrib-copy": "^1.0.0",
    "grunt-contrib-cssmin": "^2.2.1",
    "grunt-contrib-handlebars": "^2.0.0",
    "grunt-contrib-sass": "^2.0.0",
    "grunt-contrib-uglify": "^5.0.0",
    "grunt-contrib-watch": "^1.1.0",
    "grunt-text-replace": "^0.4.0",
    "handlebars": "^4.7.6",
    "lodash": "^4.17.21",
    "sass": "^1.35.1",
    "urijs": "^1.19.11"
  }
}
