{% extends 'layout/layout.twig' %}

{%- set pageTitle = 'Thank you' -%}

{% block content %}

<div class="govuk-body">
	<p class="govuk-body-l">We’ve emailed a link to <span class="govuk-!-font-weight-bold">{{ email|raw }}</span>. You’ll need to click on the link so we know this email address is correct.</p>
	<p class="govuk-body">If you have not got the email within a few minutes, please check your spam, bulk or junk email folder – your email system may have blocked it by mistake.</p>
</div>

{% endblock content %}
